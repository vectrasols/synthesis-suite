{
  "name": "synthesis",
  "version": "1.0.1",
  "description": "Synthesis - Data Analysis Suite",
  "main": "main/index.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "check:ts": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build:ts && electron .",
    "setup:backend": "node scripts/run_python.js -m pip install -r python-backend/requirements.txt",
    "smoke:backend": "node scripts/run_python.js scripts/smoke_backend.py",
    "smoke:backend:quick": "node scripts/run_python.js scripts/smoke_backend.py --quick",
    "check:js": "npm run build:ts && node --check main/index.js && node --check main/preload.js && node --check main/updater.js && node --check renderer/js/app.js && node --check renderer/js/api.js && node --check renderer/js/charts.js && node --check renderer/js/utils.js && node --check renderer/js/tabs/visualization.js && node --check renderer/js/tabs/cleaning.js && node --check renderer/js/tabs/model-training.js && node --check renderer/js/tabs/algorithms.js",
    "build:backend": "node scripts/build_backend.js",
    "build": "npm run build:ts && npm run build:backend && electron-builder",
    "build:win": "npm run build:ts && npm run build:backend && electron-builder --win",
    "build:mac": "npm run build:ts && npm run build:backend && electron-builder --mac",
    "build:linux": "npm run build:ts && npm run build:backend && electron-builder --linux",
    "pack": "npm run build:ts && npm run build:backend && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "data-analysis",
    "machine-learning",
    "visualization",
    "electron"
  ],
  "author": {
    "name": "VectraSols",
    "email": "info@vectrasols.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vectrasols/synthesis.git"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.3.4"
  },
  "build": {
    "appId": "com.synthesis.app",
    "productName": "Synthesis",
    "copyright": "Copyright © 2026 Synthesis",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main/**",
      "renderer/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "python-backend/dist",
        "to": "python-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Science",
      "maintainer": "VectraSols <info@vectrasols.com>",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "vectrasols",
      "repo": "synthesis",
      "releaseType": "release"
    }
  }
}
